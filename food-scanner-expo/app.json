{
  "expo": {
    "name": "Food ID",
    "slug": "food-scanner-expo",
    "version": "1.0.5",
    "runtimeVersion": "1.0.5",
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "orientation": "portrait",
    "icon": "./assets/icon/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "This app uses the camera to scan barcodes on food products.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "icon": "./assets/icon/composer.icon",
      "bundleIdentifier": "com.uxuiua.foodid"
    },
    "android": {
      "package": "com.uxuiua.foodid",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon/adaptive-icon.png",
        "monochromeImage": "./assets/icon/adaptive-icon.png",
        "backgroundColor": "#0f9e48"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": ["CAMERA", "android.permission.CAMERA"]
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/icon/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0f9e48"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Food ID to access your camera to scan barcodes."
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "node_modules/@expo-google-fonts/montserrat/400Regular/Montserrat_400Regular.ttf",
            "node_modules/@expo-google-fonts/montserrat/500Medium/Montserrat_500Medium.ttf",
            "node_modules/@expo-google-fonts/montserrat/600SemiBold/Montserrat_600SemiBold.ttf",
            "node_modules/@expo-google-fonts/montserrat/700Bold/Montserrat_700Bold.ttf",
            "node_modules/@expo-google-fonts/inter/400Regular/Inter_400Regular.ttf",
            "node_modules/@expo-google-fonts/inter/500Medium/Inter_500Medium.ttf",
            "node_modules/@expo-google-fonts/inter/600SemiBold/Inter_600SemiBold.ttf",
            "node_modules/@expo-google-fonts/inter/700Bold/Inter_700Bold.ttf"
          ]
        }
      ],
      "expo-video",
      "expo-localization"
    ],
    "extra": {
      "eas": {
        "projectId": "b9ee4aab-4b5f-4ea2-91a7-1571a122e53e"
      }
    },
    "owner": "uxuiua"
  }
}
